    // Audio utility functions
    function playCorrectSound() {
      if (!soundEffectsEnabled) return;
      
      const audioContext = new (window.AudioContext || window.webkitAudioContext)();
      const oscillator = audioContext.createOscillator();
      const gainNode = audioContext.createGain();
      
      oscillator.connect(gainNode);
      gainNode.connect(audioContext.destination);
      
      oscillator.frequency.value = 800;
      oscillator.type = 'sine';
      
      gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
      gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.3);
      
      oscillator.start(audioContext.currentTime);
      oscillator.stop(audioContext.currentTime + 0.3);
    }

    function playWrongSound() {
      if (!soundEffectsEnabled) return;
      
      const audioContext = new (window.AudioContext || window.webkitAudioContext)();
      const oscillator = audioContext.createOscillator();
      const gainNode = audioContext.createGain();
      
      oscillator.connect(gainNode);
      gainNode.connect(audioContext.destination);
      
      oscillator.frequency.setValueAtTime(400, audioContext.currentTime);
      oscillator.frequency.linearRampToValueAtTime(200, audioContext.currentTime + 0.3);
      oscillator.type = 'sine';
      
      gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
      gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.3);
      
      oscillator.start(audioContext.currentTime);
      oscillator.stop(audioContext.currentTime + 0.3);
    }

    function readQuestionAloud(text) {
      if (!readAloudEnabled) return;
      
      // Cancel any ongoing speech
      window.speechSynthesis.cancel();
      
      // Clean up the question text for better reading
      let cleanText = text.replace(/×/g, 'times').replace(/÷/g, 'divided by');
      
      // Highlight words as they are read
      const words = cleanText.split(/\s+/);
      const estimatedWordDuration = 450; // milliseconds per word
      
      words.forEach((word, index) => {
        setTimeout(() => {
          const wordElements = document.querySelectorAll('.question-text span');
          if (wordElements[index]) {
            wordElements[index].classList.add('word-highlight');
            setTimeout(() => {
              wordElements[index].classList.remove('word-highlight');
            }, estimatedWordDuration);
          }
        }, index * estimatedWordDuration);
      });
      
      const utterance = new SpeechSynthesisUtterance(cleanText);
      utterance.rate = 1;
      utterance.pitch = 1;
      utterance.volume = 1;
      
      // Apply selected voice if available
      if (selectedVoiceIndex > 0 && availableVoices[selectedVoiceIndex - 1]) {
        utterance.voice = availableVoices[selectedVoiceIndex - 1];
      }
      
      window.speechSynthesis.speak(utterance);
    }

    function wrapQuestionWordsWithSpans(text) {
      const words = text.split(/\s+/);
      const wrappedWords = words.map(word => `<span>${word}</span>`).join(' ');
      return wrappedWords;
    }

