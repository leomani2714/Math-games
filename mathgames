    function getRandomNumberByDigits(digits) {
      if (digits === 1) return Math.floor(Math.random() * 9) + 1;
      const min = 10 ** (digits - 1);
      const max = 10 ** digits - 1;
      return Math.floor(Math.random() * (max - min + 1)) + min;
    }

    function chooseProblemType() {
      const types = ['arithmetic'];
      if (includeAlgebra) types.push('algebra');
      if (includeSqrt) types.push('sqrt');
      return types[Math.floor(Math.random() * types.length)];
    }

    function generateArithmeticQuestion() {
      const operation = operations[Math.floor(Math.random() * operations.length)];
      const people = ['Alex', 'Maria', 'James', 'Sarah', 'Tom', 'Lisa', 'David'];
      const person = people[Math.floor(Math.random() * people.length)];
      
      let num1, num2;
      
      if (operation === '÷') {
        num2 = getRandomNumberByDigits(Math.min(problemDigits, 2));
        const quotient = getRandomNumberByDigits(Math.max(1, problemDigits - 1));
        num1 = num2 * quotient;
        currentAnswer = quotient;
        const scenarios = [
          `${person} is organizing a school fundraiser and needs to distribute ${num1} promotional t-shirts equally among ${num2} different departments. How many t-shirts will each department receive?`,
          `A bakery received ${num1} kg of flour in bulk. The baker needs to divide this equally into ${num2} separate containers for daily recipe preparation. How many kg of flour should go into each container?`,
          `${person} collected ${num1} data points from a scientific experiment. These need to be equally divided into ${num2} groups for comparative analysis. How many data points will be in each group?`
        ];
        const scenario = scenarios[Math.floor(Math.random() * scenarios.length)];
        questionEl.textContent = scenario;
        return;
      }

      num1 = getRandomNumberByDigits(problemDigits);
      num2 = getRandomNumberByDigits(Math.min(problemDigits, 2));

      if (operation === '-') {
        if (num2 > num1) [num1, num2] = [num2, num1];
        currentAnswer = num1 - num2;
        const scenarios = [
          `${person} started a online store with an inventory of ${num1} units of a particular product. After ${num2} units were sold during the first week of operation, how many units remain in inventory?`,
          `A water tank has a capacity of ${num1} liters. During irrigation, ${num2} liters was consumed. How many liters of water are still available in the tank?`,
          `A student scored ${num1} points in their first math exam. In the second exam, ${person} scored ${num2} points less than the first exam. What was the score reduction from the first exam?`
        ];
        const scenario = scenarios[Math.floor(Math.random() * scenarios.length)];
        questionEl.textContent = scenario;
      } else if (operation === '×') {
        currentAnswer = num1 * num2;
        const scenarios = [
          `A factory produces ${num1} items per day. To fulfill a large corporate order, the factory operates for ${num2} consecutive days without interruption. How many total items will be produced during this period?`,
          `${person} is organizing a community event with ${num1} tables, and each table is expected to accommodate ${num2} guests. Assuming all tables are fully occupied, what is the total number of guests expected at the event?`,
          `A pharmaceutical company manufactures ${num1} tablets per production batch. If the company needs to complete ${num2} batches to meet quarterly targets, how many tablets will be produced in total?`
        ];
        const scenario = scenarios[Math.floor(Math.random() * scenarios.length)];
        questionEl.textContent = scenario;
      } else {
        currentAnswer = num1 + num2;
        const scenarios = [
          `${person} is a freelance accountant who earned ${num1} dollars from client A and ${num2} dollars from client B during the same fiscal month. What is the total revenue generated from these two clients?`,
          `A library has ${num1} non-fiction books in its main collection. The recent donation added ${num2} more non-fiction books to the collection. How many non-fiction books does the library now have in total?`,
          `During a charity drive, ${person}'s team collected ${num1} kg of donations. Another team contributed an additional ${num2} kg. What is the combined total of donations collected by both teams?`
        ];
        const scenario = scenarios[Math.floor(Math.random() * scenarios.length)];
        questionEl.textContent = scenario;
      }
    }

    function generateAlgebraQuestion() {
      const choice = Math.random();
      const people = ['Alex', 'Maria', 'James', 'Sarah', 'Tom', 'Lisa', 'David'];
      const person = people[Math.floor(Math.random() * people.length)];
      
      if (choice < 0.16) {
        // x + a = b
        const constant = getRandomNumberByDigits(problemDigits);
        currentAnswer = getRandomNumberByDigits(Math.max(1, problemDigits - 1));
        const result = currentAnswer + constant;
        questionEl.textContent = `${person} is managing a savings account. After depositing x dollars into the account, a bonus of ${constant} dollars was added by the bank as incentive. The current balance is now ${result} dollars. Determine the original deposit amount (x).`;
      } else if (choice < 0.32) {
        // x - a = b
        const subtrahend = getRandomNumberByDigits(problemDigits);
        currentAnswer = getRandomNumberByDigits(Math.max(1, problemDigits - 1));
        const result = currentAnswer - subtrahend;
        questionEl.textContent = `A smartphone originally priced at x dollars is on clearance sale with a discount of ${subtrahend} dollars. After applying the discount, the final sale price is ${result} dollars. What was the original price (x) of the smartphone?`;
      } else if (choice < 0.48) {
        // ax = b (multiplication)
        const coefficient = Math.floor(Math.random() * 9) + 2;
        currentAnswer = getRandomNumberByDigits(Math.max(1, problemDigits - 2));
        const result = coefficient * currentAnswer;
        questionEl.textContent = `A restaurant buys identical meal packages to supply ${coefficient} branches. If the total expenditure for all branches is ${result} dollars, and each branch receives the same package cost (x), find the cost per package.`;
      } else if (choice < 0.64) {
        // x/a = b (division)
        const divisor = Math.floor(Math.random() * 5) + 2;
        currentAnswer = getRandomNumberByDigits(Math.max(1, problemDigits - 1)) * divisor;
        const result = currentAnswer / divisor;
        questionEl.textContent = `${person} is planning a road trip covering a total distance of x kilometers. The journey is scheduled to be completed over ${divisor} equal stages. If each stage covers ${result} kilometers, what is the total distance (x) of the entire trip?`;
      } else if (choice < 0.8) {
        // ax + b = c (two-step)
        const coefficient = Math.floor(Math.random() * 5) + 2;
        const b = getRandomNumberByDigits(Math.max(1, problemDigits - 2));
        currentAnswer = getRandomNumberByDigits(Math.max(1, problemDigits - 2));
        const result = coefficient * currentAnswer + b;
        questionEl.textContent = `A tutoring center charges x dollars per session. ${person} attends ${coefficient} sessions and also pays a one-time registration fee of ${b} dollars. The total investment in tutoring is ${result} dollars. Calculate the cost per session (x).`;
      } else {
        // ax - b = c (two-step with subtraction)
        const coefficient = Math.floor(Math.random() * 5) + 2;
        const b = getRandomNumberByDigits(Math.max(1, problemDigits - 2));
        currentAnswer = getRandomNumberByDigits(Math.max(1, problemDigits - 2));
        const result = coefficient * currentAnswer - b;
        questionEl.textContent = `${person} works at an hourly rate of x dollars per hour. After working ${coefficient} hours and paying ${b} dollars for equipment, the net income is ${result} dollars. Determine the hourly wage rate (x).`;
      }
    }

    function generateSqrtQuestion() {
      const min = problemDigits === 1 ? 1 : 10 ** (problemDigits - 1);
      const max = 10 ** problemDigits - 1;
      const minRoot = Math.ceil(Math.sqrt(min));
      const maxRoot = Math.floor(Math.sqrt(max));
      const root = Math.floor(Math.random() * (maxRoot - minRoot + 1)) + minRoot;
      const square = root * root;
      currentAnswer = root;
      
      const scenarios = [
        `An architect is designing a new community park with a perfectly square lawn area of ${square} square meters. To install irrigation lines along the perimeter efficiently, the architect needs to know the length of one side of the lawn. What is the side length in meters?`,
        `A construction company has acquired a square plot of land with a total area of ${square} square meters for a commercial complex project. To establish the boundaries and calculate fencing requirements, the engineers need to determine the length of one edge of the plot. What is the length of one edge in meters?`,
        `A museum is renovating one of its galleries with a square floor plan that covers ${square} square feet. The restoration team needs to order baseboard trim for the walls. To calculate the total trim length needed, they must first find the length of one wall. What is the length of one wall in feet?`,
        `A textile company manufactures square scarves with a surface area of ${square} square centimeters. Quality control requires measuring the side length of each scarf. What is the side length of the square scarf in centimeters?`,
        `A video game designer is creating a square game board with an area of ${square} pixel squares. To ensure proper placement of game elements, the designer needs to know how many pixels form one side of the board. How many pixels long is one side of the game board?`
      ];
      
      const scenario = scenarios[Math.floor(Math.random() * scenarios.length)];
      questionEl.textContent = scenario;
    }

    function generateQuestion() {
      const type = chooseProblemType();
      if (type === 'algebra') {
        generateAlgebraQuestion();
      } else if (type === 'sqrt') {
        generateSqrtQuestion();
      } else {
        generateArithmeticQuestion();
      }

      answerInput.value = '';
      answerInput.focus();
      feedbackEl.classList.remove('visible');
      feedbackEl.classList.add('hidden');
      
      currentQuestion++;
      questionNumEl.textContent = `${currentQuestion}/${totalQuestions}`;
      
      // Wrap words with spans for highlighting if reading aloud is enabled
      if (readAloudEnabled) {
        const originalText = questionEl.textContent;
        questionEl.innerHTML = wrapQuestionWordsWithSpans(originalText);
      }
      
      // Read the question aloud if enabled
      setTimeout(() => {
        readQuestionAloud(questionEl.textContent);
      }, 300);
    }

    function checkAnswer() {
      const userAnswer = parseInt(answerInput.value);
      
      if (isNaN(userAnswer)) {
        return;
      }
      
      const isCorrect = userAnswer === currentAnswer;
      
      // Record the answered question
      answeredQuestions.push({
        question: questionEl.textContent,
        userAnswer: userAnswer,
        correctAnswer: currentAnswer,
        isCorrect: isCorrect
      });
      
      if (isCorrect) {
        score++;
        scoreEl.textContent = score;
        playCorrectSound();
        createConfetti();
        createFlash(true);
        createBurstExplosion();
        createSuccessPulse();
        createScreenPulse();
        feedbackEl.innerHTML = '<div class="feedback-text"><span class="feedback-icon">✓</span><span>Correct!</span></div>';
        feedbackEl.className = 'feedback correct visible';
      } else {
        playWrongSound();
        createShake();
        createFlash(false);
        feedbackEl.innerHTML = `<div class="feedback-text"><span class="feedback-icon">✗</span><span>Wrong! Correct answer: ${currentAnswer}</span></div>`;
        feedbackEl.className = 'feedback incorrect visible';
      }
      
      setTimeout(() => {
        if (currentQuestion >= totalQuestions) {
          endGame();
        } else {
          hintUsed = false;
          hintBtn.disabled = false;
          hintBtn.style.opacity = '1';
          generateQuestion();
        }
      }, 1200);
    }

    function endGame() {
      clearInterval(timerInterval);
      gameScreen.classList.add('hidden');
      endScreen.classList.remove('hidden');
      pauseOverlay.classList.add('hidden');
      
      finalScoreEl.textContent = `${score}/${totalQuestions}`;
      
      const percentage = Math.round((score / totalQuestions) * 100);
      if (percentage >= 90) {
        finalMessageEl.textContent = '🌟 Outstanding! You\'re a math wizard!';
      } else if (percentage >= 70) {
        finalMessageEl.textContent = '👏 Great job! Keep it up!';
      } else if (percentage >= 50) {
        finalMessageEl.textContent = '👍 Good effort! Practice makes perfect!';
      } else {
        finalMessageEl.textContent = '💪 Keep practicing! You\'ll improve!';
      }
      
      // Display review and save score
      displayReview();
      addScore(score);
      savePreferences();
    }
  </script>
</body>
</html>